@{
    ViewData["Title"] = "S.O.R.A.";
}

<style>
    /* サイバーパンク風の背景とフォント設定 */
    body {
        background-color: #0d0d0d; /* 真っ黒に近い背景 */
        color: #00ffcc; /* ネオンブルー/グリーンの文字 */
        font-family: 'Courier New', Courier, monospace;
    }

    .display-4 {
        text-shadow: 0 0 10px #00ffcc, 0 0 20px #00ffcc;
        color: #00ffcc;
        margin-bottom: 30px;
    }

    @@keyframes fade-in {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ① 一番上に共通設定（1つにまとめる） */
    .message {
        width: fit-content;
        max-width: 80%;
        margin-bottom: 15px;
        padding: 10px;
        border-left: 3px solid #00ffcc; /* 基本の青線 */
        background: rgba(255, 255, 255, 0.02);
        animation: fade-in 0.5s ease-out;
    }

    /* ② その下に「あなた」の上書き設定 */
    .user-style {
        margin-left: auto;
        border-left: none; /* ここで青線を消す */
        border-right: 3px solid #ff00ff; /* 右にピンク線を出す */
        text-align: right;
    }

    /* ③ その下に「S.O.R.A.」の上書き設定 */
    .sora-style {
        margin-right: auto;
        border-left: 3px solid #ff00ff; /* 青線をピンク線に塗り替える */
        text-align: left;
    }

    /* チャット履歴のエリア */
    .chat-container {
        max-height: 500px;
        overflow-y: auto;
        border: 2px solid #00ffcc;
        background-color: rgba(0, 255, 204, 0.05);
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: inset 0 0 15px rgba(0, 255, 204, 0.2);
        border-radius: 10px;
    }

    /* 入力エリア */
    .input-group {
        display: flex;
        gap: 10px;
    }

    input[type="text"] {
        flex-grow: 1;
        background: #1a1a1a;
        border: 1px solid #00ffcc;
        color: #00ffcc;
        padding: 10px;
        outline: none;
    }

    button {
        background: #00ffcc;
        color: #0d0d0d;
        border: none;
        padding: 10px 20px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

        button:hover {
            background: #ff00ff; /* ホバー時にネオンピンクに */
            box-shadow: 0 0 15px #ff00ff;
        }
</style>

<div class="text-center">
    <h1 class="display-4">S.O.R.A.</h1>
</div>

<div class="chat-container" id="chatLog">
    @if (ViewData["ChatLog"] is List<S.O.R.A._System_Operational_Remote_Assistant_.Controllers.HomeController.ChatMessage> chatLog)
    {
        foreach (var message in chatLog)
        {
            <div class="message @(message.Sender == "あなた：" ? "user-style" : "sora-style")">
                @message.Text
            </div>
        }
    }
    else
    {
        <div class="message">SYSTEM READY... AWAITING COMMAND.</div>
    }
</div>

<form method="post" asp-controller="Home" asp-action="SendMessage" class="input-group">
    <input type="text" name="UserMessage" placeholder="Type a message..." autocomplete="off" autofocus />
    <button type="submit">Execute</button>
</form>

<script>
    // 下までスクロールする
    const container = document.getElementById("chatLog");
    if (container) {
        container.scrollTop = container.scrollHeight;
    }
</script>